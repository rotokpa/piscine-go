func punct(s string) string {
	word := strings.Fields(s)
	for i := 0; i < len(word); i++ {
		if strings.ContainsAny(word[i], ":;',.?!") {
			if i > 0 {
				word[i-1] += word[i]

				word = append(word[:i], word[i+1:]...)
				i--
			}
		}
	}
	return strings.Join(word, " ")
}

func upper(words []string) []string {
	for i := 0; i < len(words); i++ {
		if words[i] == "(up)" {
			words[i-1] = strings.ToUpper(words[i-1])

			words = append(words[:i], words[i+1:]...)
			i--
		}
	}
	return words
}

func covertTo(word []string) []string {
	for i := 0; i < len(word); i++ {
		switch strings.ToLower(word[i]) {
		case "(bin)":
			if i > 0 {
				val, err := strconv.ParseInt(word[i-1], 2, 64)
				if err != nil {
					continue
				}
				word[i-1] = strconv.FormatInt(val, 10)

				word = append(word[:i], word[i+1:]...)
				i--
			}
		case "(hex)":
			if i > 0 {
				val, err := strconv.ParseInt(word[i-1], 16, 64)
				if err != nil {
					continue
				}
				word[i-1] = strconv.FormatInt(val, 10)

				word = append(word[:i], word[i+1:]...)
				i--
			}
		}
	}
	return word
}

